# The Leopard - IOC Search App v5.0
# Backend Environment Configuration

# ============ Database ============
DB_HOST=mysql-v5
DB_PORT=3306
DB_NAME=iocdb
DB_USER=root
DB_PASSWORD=password

# ============ Server ============
PORT=4000
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ============ Proxy (Optional) ============
# Leave empty if not needed
# Used for connecting to external SIEM APIs and TI feeds
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
