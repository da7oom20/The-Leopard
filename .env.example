# ================================================================
# The Leopard - IOC Search App v5.5
# Environment Configuration Template
# ================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
#
# REQUIRED variables are marked with [REQUIRED]
# All others have sensible defaults.

# ============ Security [REQUIRED] ============

# JWT signing key — used for user authentication tokens
# Must be at least 16 characters. Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string

# Encryption key for SIEM API keys, TI tokens, and MFA secrets (AES-256-GCM)
# If not set, falls back to JWT_SECRET. Setting a separate key allows
# rotating JWT_SECRET without re-encrypting all stored credentials.
# Generate with: openssl rand -base64 32
# ENCRYPTION_KEY=

# ============ Database ============

# MySQL connection (matches docker-compose service name)
DB_HOST=mysql-v5
DB_PORT=3306
DB_NAME=iocdb
DB_USER=root
DB_PASSWORD=password

# Connection pool tuning (defaults work well for most deployments)
# DB_POOL_MAX=50        # Maximum connections in pool
# DB_POOL_MIN=5         # Minimum connections kept open
# DB_POOL_ACQUIRE=60000 # Max wait (ms) to acquire a connection
# DB_POOL_IDLE=10000    # Max idle time (ms) before connection is released

# ============ Server ============

# Backend listening port (internal, not exposed to users)
# PORT=4000

# Node.js environment
# NODE_ENV=production

# CORS allowed origin (set to your frontend URL in production)
# Default: * (allow all — fine when nginx proxies everything)
CORS_ORIGIN=*

# ============ Proxy (Optional) ============
# Used for outbound connections to external SIEM APIs and TI feeds
# Leave empty or commented out if no proxy is needed
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,frontend-v5,mysql-v5

# ============ Frontend ============
# These are build-time ARGs in docker-compose, not runtime env vars.
# REACT_APP_API_URL=/api   # Default; no need to change for standard setup
